@model X.PagedList.IPagedList<EmployeeManagementMVC.Models.Employee>
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Employee List";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">Employee Dashboard</h2>

        <a asp-action="Create" class="btn btn-primary">
            + Add Employee
        </a>
    </div>

    <!-- SUCCESS / ERROR -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- SEARCH + FILTER -->
    <form method="get" asp-action="Index" class="mb-3">

        <div class="row g-2">

            <!-- Search -->
            <div class="col-md-4">
                <input type="text" name="search" class="form-control"
                       value="@Context.Request.Query["search"]"
                       placeholder="Search by name..." />
            </div>

            <!-- Department Filter -->
            <div class="col-md-3">
                <select name="department" class="form-control">

                    <option value="">All Departments</option>

                    <option value="HR"
                            selected="@(Context.Request.Query["department"] == "HR")">
                        HR
                    </option>

                    <option value="IT"
                            selected="@(Context.Request.Query["department"] == "IT")">
                        IT
                    </option>

                    <option value="Finance"
                            selected="@(Context.Request.Query["department"] == "Finance")">
                        Finance
                    </option>

                </select>
            </div>

            <!-- Filter Button -->
            <div class="col-md-2">
                <button class="btn btn-primary w-100">Filter</button>
            </div>

            <!-- Reset -->
            <div class="col-md-2">
                <a href="/Employees" class="btn btn-secondary w-100">Reset</a>
            </div>

        </div>
    </form>

    <!-- TABLE CARD -->
    <div class="card shadow-sm">

        <div class="card-body p-0">

            <!-- TABLE -->
            <table class="table table-hover table-bordered align-middle mb-0">

                <thead class="table-dark text-center">
                    <tr>
                        <th>
                            <a class="text-white text-decoration-none"
                               asp-action="Index"
                               asp-route-sortOrder="@ViewBag.NameSort">
                                Name
                            </a>
                        </th>

                        <th>Email</th>

                        <th>
                            <a class="text-white text-decoration-none"
                               asp-action="Index"
                               asp-route-sortOrder="@ViewBag.NameSort"
                               asp-route-search="@Context.Request.Query["search"]"
                               asp-route-department="@Context.Request.Query["department"]">
                                Name
                            </a>
                        </th>

                        <th>
                            <a class="text-white text-decoration-none"
                               asp-action="Index"
                               asp-route-sortOrder="@ViewBag.SalarySort"
                               asp-route-search="@Context.Request.Query["search"]"
                               asp-route-department="@Context.Request.Query["department"]">
                                Salary
                            </a>
                        </th>

                        <th style="width: 220px;">Actions</th>
                    </tr>
                </thead>

                <tbody class="text-center">

                    @if (Model != null && Model.Any())
                    {
                        foreach (var emp in Model)
                        {
                            <tr>

                                <td class="fw-semibold">@emp.Name</td>
                                <td>
                                    <span class="badge bg-info text-dark">
                                        @emp.Department
                                    </span>
                                </td>

                                <td>₹ @emp.Salary</td>

                                <td class="d-flex justify-content-center gap-1">

                                    <a asp-action="Edit"
                                       asp-route-id="@emp.Id"
                                       class="btn btn-sm btn-warning">
                                        Edit
                                    </a>

                                    <a asp-action="Details"
                                       asp-route-id="@emp.Id"
                                       class="btn btn-sm btn-info text-white">
                                        View
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@emp.Id"
                                       class="btn btn-sm btn-danger">
                                        Delete
                                    </a>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-3">
                                No employees found
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

    <!-- PAGINATION -->
    <div class="d-flex justify-content-center mt-3">

        @Html.PagedListPager(Model, page => Url.Action("Index", new
        {
            page,
            search = Context.Request.Query["search"],
            department = Context.Request.Query["department"],
            sortOrder = Context.Request.Query["sortOrder"]
        }),
        new PagedListRenderOptions
        {
            DisplayLinkToFirstPage = PagedListDisplayMode.Always,
            DisplayLinkToLastPage = PagedListDisplayMode.Always,
            DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
            DisplayLinkToNextPage = PagedListDisplayMode.Always,
            MaximumPageNumbersToDisplay = 5,
            UlElementClasses = new[] { "pagination" },
            LiElementClasses = new[] { "page-item" }
        })

    </div>

</div>